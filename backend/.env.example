# Learn Claude Code API 环境变量配置

# ============================================
# 基础配置
# ============================================

# 应用名称
APP_NAME=Learn Claude Code API

# 应用版本
APP_VERSION=1.0.0

# 调试模式 (true/false)
DEBUG=true

# 运行环境 (development/production/testing)
ENVIRONMENT=development

# ============================================
# 服务器配置
# ============================================

# 监听地址
HOST=0.0.0.0

# 监听端口
PORT=8000

# ============================================
# CORS 配置
# ============================================

# 允许的跨域来源（逗号分隔）
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://127.0.0.1:3000

# 允许跨域携带凭证 (true/false)
CORS_CREDENTIALS=true

# ============================================
# 日志配置
# ============================================

# 日志级别 (DEBUG/INFO/WARNING/ERROR/CRITICAL)
LOG_LEVEL=INFO

# 是否使用 JSON 格式日志（生产环境推荐）
LOG_JSON=false

# ============================================
# 数据配置
# ============================================

# 前端数据目录路径（相对或绝对路径）
DATA_DIR=../web/src/data

# ============================================
# 限流配置
# ============================================

# 是否启用限流 (true/false)
RATE_LIMIT_ENABLED=true

# 每分钟最大请求数
RATE_LIMIT_REQUESTS=100

# ============================================
# 缓存配置
# ============================================

# 是否启用缓存 (true/false)
CACHE_ENABLED=true

# 缓存过期时间（秒）
CACHE_TTL=300
